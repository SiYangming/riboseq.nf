/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Oryza sativa Riboseq vs polyA RNA Analysis - Fixed Configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    ✅ Only uses VALID nf-core/riboseq parameters
    ✅ Removed invalid custom parameters that caused warnings
    ✅ All analysis modules enabled
    
    Use as follows:
        nextflow run main.nf -c riboseq.config --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

resume = true

params {
    config_profile_name        = 'Oryza sativa SRP189094'
    config_profile_description = 'Complete riboseq pipeline with all analysis modules enabled'

    riboseq_base_dir     = System.getenv('RIBOSEQ_BASE_DIR')     ?: '/Users/siyangming'
    riboseq_pipeline_dir = System.getenv('RIBOSEQ_PIPELINE_DIR') ?: "${params.riboseq_base_dir}/nextflow_nf_core/riboseq.nf"
    riboseq_project_dir  = System.getenv('RIBOSEQ_PROJECT_DIR')  ?: "${params.riboseq_base_dir}/nextflow_nf_core/riboseq.nf/SRP189094_results"
    riboseq_fasta_dir    = System.getenv('RIBOSEQ_FASTA_DIR')    ?: "${params.riboseq_base_dir}/nextflow_nf_core/riboseq.nf/testdata/reference"
    riboseq_gtf_dir      = System.getenv('RIBOSEQ_GTF_DIR')      ?: "${params.riboseq_base_dir}/nextflow_nf_core/riboseq.nf/testdata/reference"
    riboseq_rnadb_dir    = System.getenv('RIBOSEQ_RNADB_DIR')    ?: "${params.riboseq_pipeline_dir}/RNAdb"

    // ============================================================================
    // Input/Output Configuration
    // ============================================================================
    input = "${params.riboseq_pipeline_dir}/testdata/samplesheet/samplesheet_SRP189094.csv"
    contrasts = "${params.riboseq_pipeline_dir}/testdata/contrasts_SRP189094.csv"
    //outdir = "/Users/siyangming/nextflow_nf_core/riboseq.nf/SRP189094_results/"
    
    // ============================================================================
    // Reference Genome - Oryza sativa japonica (IRGSP-1.0)
    // ============================================================================
    fasta = "${params.riboseq_fasta_dir}/osa_IRGSP10.fasta"
    gtf = "${params.riboseq_gtf_dir}/osa_IRGSP1062.gtf"
    // transcript_fasta = "${params.riboseq_fasta_dir}/osa_IRGSP10_cdna.fa"
    
    // ============================================================================
    // rRNA Database Configuration
    // ============================================================================
    remove_ribo_rna = true
    ribo_database_manifest = "${params.riboseq_rnadb_dir}/rrna-db-full_local.txt"
    
    // ============================================================================
    // Alignment Configuration
    // ============================================================================
    aligner = 'star'
    skip_alignment = false
    
    // Pseudo-alignment
    pseudo_aligner = 'salmon'
    skip_pseudo_alignment = false
    
    // ============================================================================
    // Pre-processing Options
    // ============================================================================
    skip_bbsplit = true
    // bbsplit_fasta_list = null
    skip_fastqc = false
    skip_trimgalore = false
    
    // ============================================================================
    // Read Quality Control
    // ============================================================================
    min_trimmed_reads = 10
    extra_fqlint_args = '--disable-validator P001 --disable-validator S007'
    
    // ============================================================================
    // UMI Handling
    // ============================================================================
    with_umi = false
    skip_umi_extract = false
    
    // ============================================================================
    // Ribosome Footprint Analysis Tools
    // ============================================================================
    skip_ribotricer = true
    skip_ribocode = true
    skip_ribowaltz = true
    skip_anota2seq = false
    
    // ============================================================================
    // Differential Expression Analysis
    // ============================================================================
    skip_deseq2_qc = false
    
    // ============================================================================
    // Save Intermediate Files
    // ============================================================================
    save_merged_fastq = true
    save_non_ribo_reads = true
    save_bbsplit_reads = true
    save_reference = true
    save_trimmed = true
    save_align_intermeds = false
    save_unaligned = true
    save_umi_intermeds = false
    
    // ============================================================================
    // Genome Browser Files & QC
    // ============================================================================
    skip_bigwig = false
    skip_stringtie = false
    skip_dupradar = false
    skip_qualimap = false
    skip_rseqc = false
    skip_biotype_qc = false
    skip_markduplicates = false
    
    // ============================================================================
    // MultiQC Report
    // ============================================================================
    multiqc_title = 'Oryza sativa SRP189094 Riboseq vs polyA RNA Analysis - Complete Pipeline'
    skip_multiqc = false
    skip_qc = false
}

// ============================================================================
// Process Configuration
// ============================================================================

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]

    withName: RIBOCODE_METAPLOTS {
        ext.args = '-f0_percent 0.1 -pv1 1 -pv2 1'
    }
}
