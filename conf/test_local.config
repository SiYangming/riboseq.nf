/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run nf-core/riboseq -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

resume = true
workDir = './nextflow_work'

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]

    withName: RIBOCODE_METAPLOTS {
        ext.args = '-f0_percent 0.1 -pv1 1 -pv2 1'
    }
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Alignment / pseudo-alignment index parameters
    // Explicit defaults to avoid \"undefined parameter\" warnings in tests
    salmon_index          = null
    kallisto_index        = null
    skip_pseudo_alignment = false
    // salmon or kallisto
    pseudo_aligner        = 'kallisto'
    sortmerna_index       = null

    // Input data
    input = "${launchDir}/testdata/samplesheet/samplesheet_local.csv"
    contrasts = "${launchDir}/testdata/contrasts.csv"
    ribo_database_manifest = "${launchDir}/RNAdb/rrna-db-full_local.txt"
    fasta = "${launchDir}/testdata/reference/Homo_sapiens.GRCh38.dna.chromosome.20.fa.gz"
    gtf = "${launchDir}/testdata/reference/Homo_sapiens.GRCh38.111_chr20.gtf"
    min_trimmed_reads = 1000

    // Ribotricer parameters
    skip_ribotricer = true
    extra_fqlint_args = '--disable-validator P001 --disable-validator S007'
}
